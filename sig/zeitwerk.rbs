# Minimal Zeitwerk type stubs for Peddler's usage
module Zeitwerk
  class Loader
    def self.for_gem: () -> Loader

    attr_accessor inflector: Inflector

    def ignore: (String) -> void
    def setup: () -> void
  end

  class Inflector
    def camelize: (String basename, String? abspath) -> String
    def inflect: (Hash[String, String] inflections) -> void
  end

  class GemInflector < Inflector
    def initialize: (String root_file) -> void
  end
end
