# frozen_string_literal: true

# <%= Generator::Config::GENERATED_FILE_NOTICE %>

require "structure"
<% if uses_time_types? -%>
require "time"
<% end -%>

<% if namespace -%>
module Peddler
  module <%= namespace %>
    module <%= namespace_name %>
<% if class_description -%>

      <%= class_description %>
<% end -%>
      <%= class_name %> = Structure.new do
<% properties.each_with_index do |(prop_name, prop_def), index| -%>
<%= "\n" if index > 0 -%>
        <%= format_property_comment(prop_def) %>
        <%= attribute_declaration_for(prop_name, prop_def) %>
<% end -%>
      end
    end
  end
end
<% else -%>
module Peddler
  module APIs
    class <%= api_name.camelize %>
      <% if class_description -%>
        <%= class_description %>
      <% end -%>
      <%= class_name %> = Structure.new do
        <% properties.each_with_index do |(prop_name, prop_def), index| -%>
          <%= "\n" if index > 0 -%>
          <%= format_property_comment(prop_def) %>
          <%= attribute_declaration_for(prop_name, prop_def) %>
        <% end -%>
      end
    end
  end
end
<% end -%>
